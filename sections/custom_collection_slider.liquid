</style>


<div class="mobile-only-section">
  <div class="bs-gallery splide ">
      <div class="splide__track">
		<div class="splide__list">

    {% for block in section.blocks %}

      <div class="splide__slide">
        <a href="{{ block.settings.collection_link }}" class="story-link">
          <img src="{{ block.settings.collection_img | img_url: 'master'}}" alt="Coffee Flag" loading="lazy" class="story-img {{ section.settings.icon-style }}">
          <span class="badge-text">{{ block.settings.badge-text }}</span>
          <p class="story-collection-title">{{ block.settings.collection_title }}</p>
        </a>
      </div>
    {% endfor %}
        </div>
      </div>
  </div>

</div>
<script type="text/javascript">
var splide = new Splide( '.bs-gallery', {
type   : 'loop',
perPage: 3,
focus  : 'center',
autoplay: true,
height   : '10rem',
  });

  splide.mount();
</script>

