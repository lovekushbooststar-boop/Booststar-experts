
<script src="{{ 'splide.js' | asset_url }}" ></script>
<style>
  .bs-gallery {
    display:flex;
  }
.story-img img {
    position: relative;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    object-fit: cover; /* To ensure the image covers the entire area */
  }  
  span.badge-text {
    position: absolute;
    background: red;
    color: white;
    padding: 0px 10px;
    font-size: 8px;
    left: 61px;
    top: 5px;
    border-radius: 12px;
}
 .story-img {
    position: relative;
  width: 60px;
  height: 60px;
  object-fit: cover;
  margin-bottom: 10px;

/* clip-path: polygon(50% 0%, 100% 38.56%, 82.5% 100%, 17.5% 100%, 0% 38.56%); */

  }

{% if section.settings['icon-style']=='style1' %}
  
.{{section.settings.icon-style}} {
  clip-path: circle(50% at 50% 50%);
  }
  
{% elsif section.settings['icon-style']=='parallelogram' %}

.{{section.settings.icon-style}} {
clip-path: polygon(25% 0%, 100% 0%, 75% 100%, 0% 100%);
  }

{% elsif section.settings['icon-style']=='triangle' %}
  
.{{section.settings.icon-style}} {
 clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
}

{% elsif section.settings['icon-style']=='rhombus' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
}

{% elsif section.settings['icon-style']=='pentagon' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);
}

{% elsif section.settings['icon-style']=='hexagon' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
}

{% elsif section.settings['icon-style']=='heptagon' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(50% 0%, 90% 20%, 100% 60%, 75% 100%, 25% 100%, 0% 60%, 10% 20%);
}

{% elsif section.settings['icon-style']=='octagon' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
}

{% elsif section.settings['icon-style']=='nonagon' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(50% 0%, 83% 12%, 100% 43%, 94% 78%, 68% 100%, 32% 100%, 6% 78%, 0% 43%, 17% 12%);
}

{% elsif section.settings['icon-style']=='decagon' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(50% 0%, 80% 10%, 100% 35%, 100% 70%, 80% 90%, 50% 100%, 20% 90%, 0% 70%, 0% 35%, 20% 10%);
}

{% elsif section.settings['icon-style']=='bevel' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(20% 0%, 80% 0%, 100% 20%, 100% 80%, 80% 100%, 20% 100%, 0% 80%, 0% 20%);
}

{% elsif section.settings['icon-style']=='rabbet' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(0% 15%, 15% 15%, 15% 0%, 85% 0%, 85% 15%, 100% 15%, 100% 85%, 85% 85%, 85% 100%, 15% 100%, 15% 85%, 0% 85%);
}
  
{% elsif section.settings['icon-style']=='left_arrow' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(40% 0%, 40% 20%, 100% 20%, 100% 80%, 40% 80%, 40% 100%, 0% 50%);
}
  
{% elsif section.settings['icon-style']=='right_arrow' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(0% 20%, 60% 20%, 60% 0%, 100% 50%, 60% 100%, 60% 80%, 0% 80%);
}
{% elsif section.settings['icon-style']=='left_Point' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(25% 0%, 100% 0%, 100% 100%, 25% 100%, 0% 50%);
}
{% elsif section.settings['icon-style']=='right_Point' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(0% 0%, 75% 0%, 100% 50%, 75% 100%, 0% 100%);
}
{% elsif section.settings['icon-style']=='left_Chevron' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(100% 0%, 75% 50%, 100% 100%, 25% 100%, 0% 50%, 25% 0%);
}
  
{% elsif section.settings['icon-style']=='right_Chevron' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(75% 0%, 100% 50%, 75% 100%, 0% 100%, 25% 50%, 0% 0%);
}
  
{% elsif section.settings['icon-style']=='star' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
} 
  
{% elsif section.settings['icon-style']=='cross' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(10% 25%, 35% 25%, 35% 0%, 65% 0%, 65% 25%, 90% 25%, 90% 50%, 65% 50%, 65% 100%, 35% 100%, 35% 50%, 10% 50%);
}  
  
{% elsif section.settings['icon-style']=='message' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(0% 0%, 100% 0%, 100% 75%, 75% 75%, 75% 100%, 50% 75%, 0% 75%);
} 
  
{% elsif section.settings['icon-style']=='close' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(20% 0%, 0% 20%, 30% 50%, 0% 80%, 20% 100%, 50% 70%, 80% 100%, 100% 80%, 70% 50%, 100% 20%, 80% 0%, 50% 30%);
}   
{% elsif section.settings['icon-style']=='frame' %}
  
.{{section.settings.icon-style}} {
clip-path: polygon(0% 0%, 0% 100%, 25% 100%, 25% 25%, 75% 25%, 75% 75%, 25% 75%, 25% 100%, 100% 100%, 100% 0%);
} 


{% elsif section.settings['icon-style']=='circle' %}
  
.{{section.settings.icon-style}} {
clip-path: circle(50% at 50% 50%);
} 
    
{% elsif section.settings['icon-style']=='ellipse' %}
  
.{{section.settings.icon-style}} {
clip-path: ellipse(25% 40% at 50% 50%);
} 
  
  {% endif %}

  
