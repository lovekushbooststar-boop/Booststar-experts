<style>
  @media (min-width: 750px) {
    .menu-bar {
      display: none !important;
    }
  }
  .menu-bar {
    display: inline-block;
  }
  .menu-bar {
    border-top: 1px solid #ddd;
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;

    z-index: 2;
  }
  .menu-bar_item {
    font-size: 11px;
    position: relative;
    flex: 1;
    text-align: center;
    line-height: .9;
    padding: 10px 0;
  }
  a.menu-bar_item:hover {
    color: red;
    background-color:white;

  }
  .menu-bar_item img {
    height: 17px;
    width: auto;
  }
  .menu-bar_item a {
    display: block;
    text-decoration: none;
    color: {{section.settings.color_title}};
  }

