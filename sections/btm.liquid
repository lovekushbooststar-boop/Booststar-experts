<style>

@media (min-width: 750px) {
  .menu-bar {
    display: none !important;
  }
}
.menu-bar {
  display: inline-block;
}
.menu-bar {
  border-top: 1px solid #ddd;
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: {{section.settings.background_color}} !important;
  z-index: 2;
}
.menu-bar_item {
  font-size: 11px;
  position: relative;
  flex: 1;
  text-align: center;
  line-height: .9;
  padding: 2px 0;
}
a.menu-bar_item:hover {
  color: red;
  background-color:white;

}
.menu-bar_item img {
  height: 17px;
  width: auto;
}
.menu-bar_item a {
  display: block;
  text-decoration: none;
  color: {{section.settings.color_title}};
}

</style>

<div class="menu-bar">
  {%- for block in section.blocks -%}
  <div class="menu-bar_item">
    <a href="{{ block.settings.link }}">
    <img src="{{ block.settings.svg_icon| img_url:'master' }}" loading="lazy" width="100%" height="100%" alt="{{ block.settings.title }}"/>
    <div>{{ block.settings.title }}</div>
    </a>
  </div>
  {%- endfor -%}
</div>
{% schema %}
  {
    "name": "Bottom Menu",
	"settings": [

{
      "type": "select",
      "id": "announcement-style",
      "label": "Announcement Style",
      "options": [
        {
          "value": "bgcolor",
          "label": "Simple color"
        },
        {
          "value": "bg_gradient",
          "label": "Gradient"
        },
{
          "value": "bg_images",
          "label": "BG Images"
        }

      ],
      "default": "bgcolor"
    },
  
      {
       "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
      },
      
      {
  "type": "color_background",
  "id": "indigrient_background",
  "label": "Gradient Background",
  "default": "linear-gradient(#ffffff, #000000)"
},
      
      
      
      
      
  
      
      
      
      
      {
       "type": "color",
      "id": "color_title",
      "label": "Heading color",
      "default": "#000000"
      },


     {
        "type": "checkbox",
        "id": "show_bottom_menu",
        "label": "Show Bottom Menu",
        "default": true
      },
{
        "type": "checkbox",
        "id": "show_your_font_color",
        "label": "Show Your Font Color",
        "default": true
      }








      

	],
    "blocks": [
      {
        "type": "item",
        "name": "Item",
        "settings": [
          {
            "type": "image_picker",
            "id": "svg_icon",
            "label": "SVG Link"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Heading",
            "default": "Your title"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ]
  }
{% endschema %}